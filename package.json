{
  "name": "free-ai-open",
  "private": true,
  "version": "0.0.1",
  "description": "Open-source browser-based local AI assistant with privacy-first model routing.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @free-ai-open/web dev",
    "build": "pnpm --filter @free-ai-open/web build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
